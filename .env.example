# Supabase
VITE_SUPABASE_URL=http://127.0.0.1:54321
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# API (for edge functions local testing)
SUPABASE_URL=http://127.0.0.1:54321
SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# CORS (legado — Edge Functions usam Access-Control-Allow-Origin: * via _shared/cors.ts)
# ALLOWED_ORIGINS=http://localhost:5173

# AI (do not commit real keys)
OPENAI_API_KEY=sk-your-key-here
ANTHROPIC_API_KEY=sk-ant-your-key-here

# Encryption
ENCRYPTION_KEY=your-encryption-key-here

# Web Push (VAPID) — gere com: npx web-push generate-vapid-keys
VITE_VAPID_PUBLIC_KEY=your-vapid-public-key
# Secrets das Edge Functions (supabase secrets set):
# VAPID_PUBLIC_KEY=...
# VAPID_PRIVATE_KEY=...
# VAPID_SUBJECT=mailto:contato@sua-clinica.com
# CRON_SECRET=...  (mesmo valor em vault.create_secret(..., 'cron_secret'))
